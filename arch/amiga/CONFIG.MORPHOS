#!/bin/sh

[ -z "$MORPHOS_PREFIX" ] && { echo "Please define \$MORPHOS_PREFIX. Aborting."; exit 1; }

./config.sh --platform amiga --host ppc-morphos --prefix "$MORPHOS_PREFIX" \
            --enable-release --enable-lto --disable-modular --enable-meter \
            --enable-sdl1 --disable-gl --enable-tremor-lowmem "$@"
